<% layout("/layouts/boilerplate") %>

<div class="row">
  <div class="col-md-8 offset-md-2 col-lg-6 offset-lg-3">
    <br><br>
    <h3 class="mb-4">Edit Listing</h3>

    <form method="POST" action="/listings/<%= listing._id %>?_method=PUT">

      <!-- Title -->
      <div class="mb-3">
        <label class="form-label">Title</label>
        <input
          type="text"
          name="listing[title]"
          value="<%= listing.title %>"
          class="form-control"
          required
        >
      </div>

      <!-- Description -->
      <div class="mb-3">
        <label class="form-label">Description</label>
        <textarea
          name="listing[description]"
          class="form-control"
          required
        ><%= listing.description %></textarea>
      </div>

      <!-- Price -->
      <div class="row">

  <!-- Price -->
  <div class="col-lg-6 mb-3">
    <label class="form-label">Price</label>
    <input
      type="number"
      name="listing[price]"
      value="<%= listing.price %>"
      placeholder="Enter price per night"
      class="form-control"
      required
    >
  </div>

  <!-- Country -->
  <div class="col-lg-6 mb-3">
    <label class="form-label">Country</label>
    <input
      type="text"
      name="listing[country]"
      value="<%= listing.country %>"
      placeholder="Enter country"
      class="form-control"
    >
  </div>

</div>


      <!-- Image URL -->
      <div class="mb-3">
        <label class="form-label">Image URL</label>
        <input
          type="text"
          name="listing[image][url]"
          value="<%= listing.image.url %>"
          class="form-control"
        >
        <!-- keep filename intact -->
        <input
          type="hidden"
          name="listing[image][filename]"
          value="<%= listing.image.filename %>"
        >
      </div>

      <!-- Location -->
      <div class="mb-3">
        <label class="form-label">Location</label>
        <input
          type="text"
          name="listing[location]"
          value="<%= listing.location %>"
          class="form-control"
        >
      </div>

      <!-- Country -->
      

      <button class=" btn-primary">Update Listing</button>

    </form>

  </div>
</div>
