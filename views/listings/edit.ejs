<% layout("/layouts/boilerplate") %>
<% const imageUrl = typeof listing.image === "string"
  ? listing.image
  : (listing.image && listing.image.url)
    ? listing.image.url
    : ""; %>
<% const imageFilename = listing.image && listing.image.filename ? listing.image.filename : "listingimage"; %>

<div class="row">
  <div class="col-md-8 offset-md-2 col-lg-6 offset-lg-3">
    <br><br>
    <h3 class="mb-4">Edit Listing</h3>

    <form method="POST" action="/listings/<%= listing._id %>?_method=PUT">
      <div class="mb-3">
        <label class="form-label">Title</label>
        <input
          type="text"
          name="listing[title]"
          value="<%= listing.title %>"
          class="form-control"
          required
        >
      </div>

      <div class="mb-3">
        <label class="form-label">Description</label>
        <textarea
          name="listing[description]"
          class="form-control"
          required
        ><%= listing.description %></textarea>
      </div>

      <div class="row">
        <div class="mb-3 col-4">
          <label class="form-label">Price</label>
          <input
            type="number"
            name="listing[price]"
            value="<%= listing.price %>"
            class="form-control"
            placeholder="1200"
            required
          >
        </div>

        <div class="mb-3 col-8">
          <label class="form-label">Country</label>
          <input
            type="text"
            name="listing[country]"
            value="<%= listing.country %>"
            class="form-control"
            placeholder="India"
          >
        </div>
      </div>

      <div class="mb-3">
        <label class="form-label">Image URL</label>
        <input
          type="text"
          name="listing[image][url]"
          value="<%= imageUrl %>"
          class="form-control"
          placeholder="Paste image link"
        >
        <input
          type="hidden"
          name="listing[image][filename]"
          value="<%= imageFilename %>"
        >
      </div>

      <div class="mb-3">
        <label class="form-label">Location</label>
        <input
          type="text"
          name="listing[location]"
          value="<%= listing.location %>"
          class="form-control"
          placeholder="BodhGaya, Bihar"
        >
      </div>

      <button class="btn-primary">Update Listing</button>
      <br><br>
    </form>
  </div>
</div>
